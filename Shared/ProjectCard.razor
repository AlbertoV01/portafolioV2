@using portafolioV2.Models
@inherits OwningComponentBase


<div class="project-card" @key="Project?.Title">
    <img class="project-screenshot img-fluid" loading="lazy" src="@Project?.ImageUrl" alt="@Project?.Title" />
    <div class="project-body">
        <h3 class="project-title">@Project?.Title</h3>
        <p class="desc">@Project?.ShortDescription</p>

        <div class="tech-row">
            <Virtualize Items="Project?.Technologies" Context="tech">
                <img class="tech-icon img-fluid" loading="lazy" src="@tech.IconUrl" alt="@tech.Name" title="@tech.Name" />
            </Virtualize>
        </div>

        <div class="links">
            @if(!string.IsNullOrWhiteSpace(Project?.GitUrl))
            {
                <a target="_blank" href="@Project.GitUrl" class="btn">GitHub</a>
            }
            @if(!string.IsNullOrWhiteSpace(Project?.DemoUrl))
            {
                <a target="_blank" href="@Project.DemoUrl" class="btn outline">Demo</a>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public ProjectItem ?Project { get; set; }
}
